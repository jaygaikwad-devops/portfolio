<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Jayvardhan Gaikwad — DevOps | Cloud | MLOps Engineer</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
:root {
  --bg: #050816;
  --card: rgba(255,255,255,0.04);
  --border: rgba(255,255,255,0.08);
  --accent: #4f9cf9;
  --accent2: #7c3aed;
  --text: #e5e7eb;
  --muted: #94a3b8;
}

* { margin:0; padding:0; box-sizing:border-box; }

body {
  font-family: 'Inter', sans-serif;
  background: radial-gradient(circle at 20% 20%, #0a0f2c, #050816);
  color: var(--text);
}

/* NAV */
nav {
  display:flex;
  justify-content:space-between;
  padding:1.5rem 3rem;
  backdrop-filter: blur(10px);
}
nav a { color:var(--muted); text-decoration:none; margin-left:20px; }
nav a:hover { color:var(--accent); }

/* HERO */
.hero {
  text-align:center;
  padding:120px 20px 80px;
  max-width:900px;
  margin:auto;
}

.hero h1 {
  font-size: clamp(2.5rem,5vw,4rem);
  font-weight:800;
  line-height:1.2;
}

.gradient {
  background: linear-gradient(90deg,#4f9cf9,#7c3aed);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}

.hero p {
  color:var(--muted);
  margin-top:20px;
  font-size:1.1rem;
}

.badge {
  display:inline-block;
  margin-bottom:20px;
  padding:6px 12px;
  border-radius:50px;
  background:rgba(79,156,249,0.1);
  color:var(--accent);
  font-size:0.8rem;
}

/* BUTTON */
.btn {
  margin-top:30px;
  display:inline-block;
  padding:12px 24px;
  border-radius:8px;
  background: linear-gradient(90deg,#4f9cf9,#7c3aed);
  color:white;
  text-decoration:none;
  font-weight:600;
}

/* CARDS */
.section {
  padding:80px 20px;
  max-width:1100px;
  margin:auto;
}

.grid {
  display:grid;
  grid-template-columns: repeat(auto-fit,minmax(280px,1fr));
  gap:20px;
}

.card {
  background: var(--card);
  border:1px solid var(--border);
  border-radius:16px;
  padding:25px;
  backdrop-filter: blur(12px);
  transition:0.3s;
}

.card:hover {
  transform: translateY(-6px);
  border-color: var(--accent);
}

.card h3 { margin-bottom:10px; }
.card p { color:var(--muted); }

/* FOOTER */
footer {
  text-align:center;
  padding:60px 20px;
  border-top:1px solid var(--border);
  color:var(--muted);
}

</style>
</head>

<body>

<nav>
  <div><b>JAY.G</b></div>
  <div>
    <a href="#projects">Projects</a>
    <a href="#skills">Skills</a>
    <a href="#contact">Contact</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="badge">Available for DevOps / MLOps Roles</div>

  <h1>
    I Build <span class="gradient">Scalable Cloud & AI Infrastructure</span>
  </h1>

  <p>
    DevOps & MLOps Engineer specializing in Kubernetes, GPU workloads,
    and production-grade cloud systems across AWS & Azure.
  </p>

  <a href="https://www.linkedin.com/" class="btn">Hire Me</a>
</section>

<!-- PROJECTS -->
<section class="section" id="projects">
  <h2>Featured Work</h2>

  <div class="grid">
    <div class="card">
      <h3>70% Cost Reduction System</h3>
      <p>Built intelligent data lifecycle using TimescaleDB + S3.</p>
    </div>

    <div class="card">
      <h3>MLOps Platform</h3>
      <p>Self-healing pipelines with auto retraining and monitoring.</p>
    </div>

    <div class="card">
      <h3>Kubernetes Platform</h3>
      <p>Internal developer platform with GitOps automation.</p>
    </div>
  </div>
</section>

<!-- SKILLS -->
<section class="section" id="skills">
  <h2>Core Skills</h2>

  <div class="grid">
    <div class="card">Kubernetes / Docker / Helm</div>
    <div class="card">Terraform / IaC</div>
    <div class="card">AWS / Azure</div>
    <div class="card">MLOps / GPU Infra</div>
  </div>
</section>

<!-- CONTACT -->
<section class="section" id="contact">
  <h2>Let’s Work Together</h2>
  <p style="color:var(--muted);margin-top:10px;">
    Open for remote roles, freelance, and high-impact DevOps projects.
  </p>
</section>

<footer>
  © 2026 Jayvardhan Gaikwad — DevOps Engineer
</footer>

</body>
</html>
